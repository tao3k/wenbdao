{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "xiuxian_wendao.link_graph.suggested_link.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "suggestion_id",
    "schema",
    "source_id",
    "target_id",
    "relation",
    "confidence",
    "evidence",
    "agent_id",
    "created_at_unix",
    "updated_at_unix",
    "promotion_state"
  ],
  "properties": {
    "suggestion_id": {
      "type": "string",
      "minLength": 1
    },
    "schema": {
      "type": "string",
      "const": "xiuxian_wendao.link_graph.suggested_link.v1"
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "relation": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "string",
      "minLength": 1
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at_unix": {
      "type": "number",
      "minimum": 0
    },
    "updated_at_unix": {
      "type": "number",
      "minimum": 0
    },
    "promotion_state": {
      "type": "string",
      "enum": ["provisional", "promoted", "rejected"]
    },
    "decision_by": {
      "type": ["string", "null"]
    },
    "decision_reason": {
      "type": ["string", "null"]
    }
  }
}
